{
  "menus": [
    {
      "name": "dm_welcome",
      "background": "#000000c8",
      "style": { "compact": true, "transparent": true },
      "closeCommand": "forcemenuoff; worr_welcome_continue",
      "items": [
        { "type": "action", "label": "Welcome to", "align": "center", "selectable": false },
        { "type": "action", "labelCvar": "ui_welcome_title", "align": "center", "selectable": false },
        { "type": "blank" },
        {
          "type": "action",
          "labelCvar": "ui_welcome_hostname",
          "align": "center",
          "selectable": false,
          "showIf": ["ui_welcome_hostname"]
        },
        { "type": "blank", "showIf": ["ui_welcome_hostname"] },
        {
          "type": "wrappedtext",
          "labelCvar": "ui_welcome_motd",
          "align": "left",
          "maxLines": 5,
          "showIf": ["ui_welcome_motd"]
        },
        { "type": "blank", "showIf": ["ui_welcome_motd"] },
        {
          "type": "action",
          "label": "Continue",
          "align": "left",
          "command": "forcemenuoff; worr_welcome_continue"
        }
      ]
    },
    {

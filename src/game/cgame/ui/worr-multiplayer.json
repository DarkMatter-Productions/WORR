        {
          "type": "action",
          "label": "Player Stats",
          "align": "left",
          "command": "worr_matchstats_menu",
          "showIf": ["ui_dm_show_matchstats=1"]
        },
        { "type": "action", "label": "---", "align": "center", "selectable": false },
        {
          "type": "action",
          "label": "Admin",
          "align": "left",
          "command": "worr_admin_menu",
          "showIf": ["ui_dm_show_admin=1"]
        },
        { "type": "action", "label": "---", "align": "center", "selectable": false },
        {
          "type": "action",
          "label": "$m_settings",
          "align": "left",
          "command": "pushmenu options"

        { "type": "action", "label": "---", "align": "center", "selectable": false },
        { "type": "action", "label": "visit darkmatter-quake.com", "align": "center", "selectable": false },
        { "type": "action", "label": ":: community :: matches ::", "align": "center", "selectable": false },

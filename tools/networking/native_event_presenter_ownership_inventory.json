  ],
  "conditions": {
    "legacy-until-negotiated-cutover": "Legacy presentation remains authoritative unless a separately negotiated, exhaustive event-effect cutover confirms every carrier family for the bound map epoch.",
    "raw-suppressed-after-cutover": "The decoded raw carrier is still captured, but its legacy presenter is skipped only while CL_NativeReadinessPilotOwnsEventPresentation() is true for the bound map epoch.",
    "embedded-suppressed-after-cutover": "The decoded snapshot event remains available for capture and audit, but its legacy one-shot presenter is skipped only while the ROM ownership cvar is set for the bound map epoch.",
    "probe-never-owns": "The map-latched cg_native_event_preflight_probe path performs full resource and fence preflight, commits telemetry only, emits no effect, and never claims raw ownership.",
    "native-authority-dormant": "Native effect emission additionally requires CG_NativeEventPresenterSetEffectAuthority(true); no production caller or negotiated cutover currently supplies that transition.",
    "whole-stream-release": "An owned map epoch releases raw suppression only at an explicit whole-stream boundary; transport drain alone must not restore the legacy presenter."
  },

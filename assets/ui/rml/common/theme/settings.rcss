/*
 * Shared settings layout and typed control treatment for RmlUi menu pages.
 */

.settings-screen
{
	display: flex;
	flex-direction: column;
	min-height: 0px;
}

.settings-form
{
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	width: 604px;
	max-width: 100%;
	height: auto;
	min-height: 0px;
	min-width: 0px;
	margin-bottom: 12px;
	padding-right: 8px;
	overflow: auto;
}

.settings-section
{
	display: flex;
	flex-direction: column;
	width: 592px;
	margin-bottom: 12px;
	padding-bottom: 8px;
	border-bottom-width: 1px;
	border-bottom-color: #332d23;
}

.settings-section h2
{
	margin-bottom: 6px;
	color: #ffd967;
	font-size: 18px;
}

.setting-row
{
	display: flex;
	flex-direction: row;
	align-items: center;
	width: 584px;
	min-height: 38px;
	margin-bottom: 6px;
	padding: 5px 8px;
	background-color: #171511;
	border-width: 1px;
	border-color: #242019;
	border-left-width: 3px;
	border-left-color: #332d23;
	border-radius: 5px;
	transition: background-color border-color color 0.12s cubic-out;
}

.setting-row:hover
{
	background-color: #211e19;
	border-left-color: #b99b5b;
}

.setting-widget-icon
{
	display: none;
	flex: 0 0 auto;
	width: 0px;
	height: 0px;
	min-width: 0px;
	min-height: 0px;
	margin-right: 0px;
	opacity: 0.88;
}

.setting-widget-icon img
{
	display: block;
	width: 16px;
	height: 16px;
	min-width: 16px;
	min-height: 16px;
}

.setting-row:hover .setting-widget-icon
{
	opacity: 1.0;
}

.setting-row[data-control="select"],
.setting-row[data-control="combo"],
.setting-row[data-control="imagevalues"]
{
	border-left-color: #8d7447;
}

.setting-row[data-control="range"]
{
	border-left-color: #426f72;
}

.setting-row[data-control="toggle"]
{
	border-left-color: #4c6f4f;
}

.setting-row[data-control="field"]
{
	border-left-color: #77644d;
}

.setting-row[data-control="action"]
{
	border-left-color: #7b5f37;
}

.setting-row[data-control="progress"]
{
	border-left-color: #578f94;
}

.setting-row[data-control="select"]:hover,
.setting-row[data-control="combo"]:hover,
.setting-row[data-control="imagevalues"]:hover
{
	border-left-color: #ffd967;
}

.setting-row[data-control="range"]:hover,
.setting-row[data-control="progress"]:hover
{
	border-left-color: #7ed4d8;
}

.setting-row[data-control="toggle"]:hover
{
	border-left-color: #83d18f;
}

.setting-row label
{
	display: block;
	width: 160px;
	margin-right: 12px;
	color: #c9beb0;
	font-weight: bold;
	white-space: normal;
	word-break: break-word;
}

.setting-row:hover label
{
	color: #f3eee4;
}

.setting-row input,
.setting-row select
{
	width: 288px;
}

.setting-row[data-control="field"] input
{
	width: 220px;
	decorator: image(../skins/widgets/textbox-normal.svg);
}

.setting-row[data-control="field"] input:hover
{
	decorator: image(../skins/widgets/textbox-hover.svg);
}

.setting-row[data-control="field"] input:focus
{
	decorator: image(../skins/widgets/textbox-focus.svg);
}

.setting-row[data-control="field"] input:disabled,
.setting-row[data-control="field"] input[disabled]
{
	decorator: image(../skins/widgets/textbox-disabled.svg);
}

.setting-row[data-control="field"] input[type="number"]
{
	width: 150px;
}

.setting-row[data-control="select"] select,
.setting-row[data-control="combo"] select,
.setting-row[data-control="imagevalues"] select
{
	width: 288px;
}

.setting-row[data-control="combo"] select,
.setting-row[data-control="imagevalues"] select
{
	decorator: image(../skins/widgets/combo-normal.svg);
}

.setting-row[data-control="combo"] select:hover,
.setting-row[data-control="imagevalues"] select:hover
{
	decorator: image(../skins/widgets/combo-hover.svg);
}

.setting-row[data-control="combo"] select:focus,
.setting-row[data-control="imagevalues"] select:focus
{
	decorator: image(../skins/widgets/combo-focus.svg);
}

.setting-row[data-control="combo"] select:disabled,
.setting-row[data-control="combo"] select[disabled],
.setting-row[data-control="imagevalues"] select:disabled,
.setting-row[data-control="imagevalues"] select[disabled]
{
	decorator: image(../skins/widgets/combo-disabled.svg);
}

.setting-row[data-control="range"] input,
.setting-row .worr-slider
{
	width: 260px;
	background-color: #111a1b;
	border-left-width: 4px;
	border-left-color: #578f94;
	border-right-color: #293f41;
}

.setting-row[data-control="range"] .setting-value
{
	width: 84px;
}

.setting-row[data-control="toggle"] label
{
	width: 500px;
}

.setting-row[data-control="toggle"] input
{
	width: 36px;
	min-width: 36px;
	height: 28px;
	min-height: 28px;
	padding: 0px;
}

.setting-row[data-control="toggle"] input:checked
{
	background-color: #1f3324;
	border-color: #83d18f;
}

.setting-row[data-control="toggle"] input:hover,
.setting-row[data-control="toggle"] input:focus
{
	background-color: #332d23;
	border-color: #ffd967;
}

.setting-row[data-control="toggle"] input:checked:hover,
.setting-row[data-control="toggle"] input:checked:focus
{
	background-color: #294830;
	border-color: #c7f0a1;
}

.setting-row[data-control="progress"] progress
{
	width: 288px;
	height: 28px;
}

.setting-row[data-control="progress"] .setting-value
{
	width: 84px;
}

.setting-row[data-control="action"] button
{
	width: 144px;
	min-width: 144px;
	height: 30px;
	padding: 5px 14px;
}

#downloads-settings-form
{
	flex: 1 1 auto;
	height: auto;
}


}

.setting-value
{
	display: block;
	width: 86px;
	min-height: 21px;
	margin-left: 10px;
	padding: 3px 0px;
	background-color: #100f0d;
	color: #c9beb0;
	border-width: 1px;
	border-color: #443d33;
	border-radius: 3px;
	font-size: 14px;
	line-height: 1.1;
	text-align: center;
	white-space: normal;
	word-break: break-word;
}

.setting-value.setting-meter
{
	position: relative;
	min-height: 21px;
	padding: 0px;
	overflow: hidden;
	background-color: #0c1314;
	border-color: #31474a;
}

.setting-meter-fill
{
	position: absolute;
	top: 0px;
	bottom: 0px;
	left: 0px;
	display: block;
	width: 0%;
	height: 100%;
	background-color: #244f53;
	border-right-width: 1px;
	border-right-color: #7ed4d8;
}

.setting-meter-text
{
	position: relative;
	display: block;
	width: 100%;
	padding: 3px 0px;
	color: #d9eee8;
	text-align: center;
}

.setting-row:hover .setting-value
{
	color: #ffd967;
}

.setting-row:hover .setting-meter-fill
{
	background-color: #2f6267;
	border-right-color: #a6edf0;
}

.setting-row:hover .setting-meter-text
{
	color: #ffffff;
}

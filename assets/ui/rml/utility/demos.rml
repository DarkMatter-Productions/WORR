<rml>
  <head>
    <title>WORR Demo Browser</title>
    <link type="text/rcss" href="../common/theme/base.rcss" />
    <link type="text/rcss" href="../common/theme/utility.rcss" />
    <link type="text/rcss" href="../common/theme/accessibility.rcss" />
  </head>
  <body id="utility-demos" data-route-id="demos" data-route-group="utility" data-route-version="1" data-document-status="round2-scaffold" data-owner="agent5" data-menu-music="menu" data-menu-sound-open="open">
    <div class="screen" id="demos-screen">
      <header class="page-header">
        <h1>Demos</h1>
        <p id="demos-summary">
          Recorded demos.
        </p>
      </header>

      <section class="toolbar" id="demos-toolbar" data-model="demo_browser">
        <button id="demos-up" type="button" data-command="demos.parent_directory" data-menu-sound="open">Up</button>
        <button id="demos-refresh" type="button" data-command="demos.refresh" data-menu-sound="change">Refresh</button>
        <button id="demos-play" type="button" data-command="demos.play_selected" data-menu-sound="confirm">Play</button>
        <button id="demos-back" type="button" data-command="ui.back" data-menu-sound="cancel">Back</button>
      </section>

      <section class="content" id="demos-content">
        <table id="demos-table" class="data-table" data-model="demo_browser.entries" data-controller="shared.table">
          <thead>
            <tr>
              <th data-sort-key="name">Name</th>
              <th data-sort-key="type">Type</th>
              <th data-sort-key="date">Date</th>
              <th data-sort-key="size">Size</th>
            </tr>
          </thead>
          <tbody>
            <tr class="placeholder-row">
              <td colspan="4">No demos found.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <footer class="status-bar" id="demos-status" data-bind="demo_browser.status">
        Demo browser ready.
      </footer>
    </div>
  </body>
</rml>
